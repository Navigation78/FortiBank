
# ── Supabase 
# Found in: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App 
# Local development URL — update to your production URL on deploy
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Resend (email service) 
# Found in: resend.com → API Keys
# Used for: phishing simulation emails + alert notifications
RESEND_API_KEY=re_your_resend_api_key_here

# ── Email sender
# The from address used when sending emails via Resend.
# Must be a verified domain in your Resend account.
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=FortiBank Security
